{
  "model": {
    "provider": "deepseek",
    "baseUrl": "https://api.deepseek.com",
    "model": "deepseek-chat",
    "apiKeyEnv": "DEEPSEEK_API_KEY"
  },
  "permission": {
    "mode": "safe"
  },
  "workspace": {
    "ignore": [
      "node_modules",
      ".git",
      "dist",
      "build",
      ".env",
      ".agent",
      ".DS_Store",
      "PROJECT_DESCRIPTION.local.md",
      "TODO.local.md",
      "ARCHITECTURE.local.md"
    ]
  }
}
