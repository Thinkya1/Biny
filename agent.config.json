{
  "model": {
    "provider": "deepseek",
    "baseUrl": "https://api.deepseek.com",
    "model": "deepseek-chat",
    "apiKeyEnv": "DEEPSEEK_API_KEY"
  },
  "permission": {
    "mode": "full-access",
    "allowTools": [
      "read_file",
      "list_files",
      "search_files",
      "grep_search",
      "git_status",
      "git_diff"
    ],
    "allowPaths": [],
    "denyPaths": [
      ".env",
      ".env.local",
      ".ssh/",
      "node_modules/"
    ],
    "criticalAlwaysAsk": true
  },
  "workspace": {
    "ignore": [
      "node_modules",
      ".git",
      "dist",
      "build",
      ".env",
      ".agent",
      ".DS_Store",
      "PROJECT_DESCRIPTION.local.md",
      "TODO.local.md",
      "ARCHITECTURE.local.md"
    ]
  }
}
