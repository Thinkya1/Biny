{
  "defaultModel": "deepseek-v4-pro",
  "providers": {
    "deepseek": {
      "type": "deepseek",
      "baseUrl": "https://api.deepseek.com",
      "apiKeyEnv": "DEEPSEEK_API_KEY"
    }
  },
  "models": {
    "deepseek-v4-flash": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "displayName": "DeepSeek V4 Flash",
      "thinking": {
        "efforts": [
          "high",
          "max"
        ],
        "defaultEffort": "high"
      }
    },
    "deepseek-v4-pro": {
      "provider": "deepseek",
      "model": "deepseek-v4-pro",
      "displayName": "DeepSeek V4 Pro",
      "thinking": {
        "efforts": [
          "high",
          "max"
        ],
        "defaultEffort": "high"
      }
    }
  },
  "thinking": {
    "enabled": true,
    "effort": "high"
  },
  "permission": {
    "mode": "full-access",
    "allowTools": [
      "read_file",
      "list_files",
      "search_files",
      "grep_search",
      "git_status",
      "git_diff"
    ],
    "allowPaths": [],
    "denyPaths": [
      ".env",
      ".env.local",
      ".ssh/",
      "node_modules/"
    ],
    "criticalAlwaysAsk": true
  },
  "workspace": {
    "ignore": [
      "node_modules",
      ".git",
      "dist",
      "build",
      ".env",
      ".agent",
      ".DS_Store",
      "PROJECT_DESCRIPTION.local.md",
      "TODO.local.md",
      "ARCHITECTURE.local.md"
    ]
  },
  "context": {
    "maxInputTokens": 24000,
    "instructionsMaxBytes": 32768,
    "memory": {
      "enabled": true
    }
  }
}
