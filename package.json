{
  "name": "@biny012/biny",
  "version": "0.2.1",
  "type": "module",
  "main": "out/main/index.js",
  "bin": {
    "biny": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "pnpm build:cli && pnpm build:desktop",
    "build:cli": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "build:desktop": "electron-vite build",
    "desktop:dev": "electron-vite dev",
    "desktop:preview": "electron-vite preview",
    "desktop:pack": "pnpm build:desktop && electron-builder --mac dir",
    "desktop:dist": "pnpm build:desktop && electron-builder --mac dmg zip",
    "dev": "node --import tsx src/cli/index.ts",
    "lint": "eslint electron.vite.config.ts scripts src tests",
    "test": "tsx tests/ai-sdk-agent.test.ts && tsx tests/tui-transcript.test.ts && tsx tests/desktop.test.ts && tsx tests/context.test.ts && tsx tests/llm-provider.test.ts && tsx tests/extensions.test.ts && tsx tests/web-search.test.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.desktop.json",
    "start": "node dist/cli/index.js",
    "prepack": "pnpm build:cli"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^2.0.9",
    "@ai-sdk/anthropic": "^4.0.12",
    "@ai-sdk/deepseek": "^3.0.7",
    "@ai-sdk/moonshotai": "^3.0.9",
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/openai-compatible": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^7.0.22",
    "commander": "^13.1.0",
    "highlight.js": "^11.11.1",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6"
  },
  "packageManager": "pnpm@10.6.5"
}
